    "        ('TOI',                int(sum(s == 'toi'             for s in rad_src))),\n",
    "        ('SIMBAD',             int(sum(s == 'simbad'          for s in rad_src))),\n",
    "        ('Mann 2015 (M_Ks)',   int(sum(s.startswith('mann_mks')  for s in rad_src))),\n",
    "        ('Torres 2010',        int(sum(s.startswith('torres')    for s in rad_src))),\n",
