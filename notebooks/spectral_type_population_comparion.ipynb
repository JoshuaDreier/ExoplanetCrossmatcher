    "def _investigate_missing(host_name):\n",
    "    rows = e_emc[e_emc[\"host\"] == host_name]\n",
    "    if len(rows) == 0:\n",
    "        print(f\"{host_name}: not found in full_emc\"); return\n",
    "    r = rows[0]\n",
    "\n",
    "    # Distance\n",
    "    dist = float(rows[\"sy_dist\"][0]) if \"sy_dist\" in rows.colnames else np.nan\n",
    "    main_id = str(r[\"main_id\"]).strip()\n",
    "    alias_col = \"main_id_aliases\"\n",
    "    raw = str(r[alias_col] if alias_col in rows.colnames else \"\")\n",
    "    aliases = set()\n",
    "    for space_tok in raw.split():\n",
    "        for tok in space_tok.split(\",\"):\n",
    "            t = tok.strip()\n",
    "            if t: aliases.add(t)\n",
    "    aliases.add(host_name)\n",
    "    aliases.add(main_id)\n",
    "\n",
    "    # ID match\n",
    "    id_hit = [(a, hpic_names_norm[norm(a)]) for a in aliases if norm(a) in hpic_names_norm]\n",
    "\n",
    "    # Coordinate match\n",
    "    ra  = float(rows[\"main_id_ra\"][0])\n",
    "    dec = float(rows[\"main_id_dec\"][0])\n",
    "    coord = SkyCoord(ra=ra*u.deg, dec=dec*u.deg)\n",
    "    seps = coord.separation(hpic_coords)\n",
    "    closest_idx = seps.argmin()\n",
    "    closest_sep = seps[closest_idx].to(u.arcmin)\n",
    "\n",
    "    print(f\"{'─'*55}\")\n",
    "    print(f\"  Host:      {host_name}  (main_id: {main_id})\")\n",
    "    print(f\"  Distance:  {dist:.1f} pc  {'← beyond 50 pc limit' if dist > 50 else '← within 50 pc'}\")\n",
    "    print(f\"  RA/Dec:    {ra:.4f}°  {dec:.4f}°\")\n",
    "    if id_hit:\n",
    "        print(f\"  ID match:  {id_hit}\")\n",
    "    else:\n",
    "        print(f\"  ID match:  none  ({len(aliases)} aliases tried)\")\n",
    "    print(f\"  Coord:     closest HPIC = '{input_table['star_name'][closest_idx]}'  \"\n",
    "          f\"({closest_sep:.2f})\")\n",
    "    print()\n",
    "\n",
    "for host in (\"TOI-700\", \"GJ 12\", \"LP 890-9\"):\n",
    "    _investigate_missing(host)"
   ]
