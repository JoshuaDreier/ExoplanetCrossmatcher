    "from astropy.coordinates import SkyCoord\n",
    "import astropy.units as u\n",
    "\n",
    "# ── Get TOI-700 EMC row ───────────────────────────────────────────────────────\n",
    "toi700_rows = e_emc[e_emc[\"host\"] == \"TOI-700\"]\n",
    "emc_row = toi700_rows[0]   # all planets share the same host params\n",
    "\n",
    "# ── ID crossmatch ─────────────────────────────────────────────────────────────\n",
    "alias_col = \"main_id_aliases\"\n",
    "raw_aliases = str(emc_row[alias_col] if alias_col in toi700_rows.colnames else \"\")\n",
    "candidate_ids = set()\n",
    "for field in (\"host\", \"main_id\"):\n",
    "    val = str(emc_row[field]).strip()\n",
    "    if val and val != \"--\":\n",
    "        candidate_ids.add(val)\n",
    "# aliases are space-separated; each space-token may itself be comma-separated\n",
    "for space_tok in raw_aliases.split(\",\"):\n",
    "    for tok in space_tok.split(\",\"):\n",
    "        t = tok.strip()\n",
    "        if t:\n",
    "            candidate_ids.add(t)\n",
    "\n",
    "\n",
    "\n",
    "def norm(s): return \" \".join(str(s).split())\n",
    "hpic_names_norm = {norm(n): n for n in input_table[\"star_name\"]}\n",
    "\n",
    "id_matches = [(cid, hpic_names_norm[norm(cid)])\n",
    "              for cid in candidate_ids\n",
    "              if norm(cid) in hpic_names_norm]\n",
    "\n",
    "print(\"── ID crossmatch ────────────────────────────────\")\n",
    "if id_matches:\n",
    "    for cid, hname in id_matches:\n",
    "        print(f\"  EMC alias '{cid}'  →  HPIC '{hname}'\")\n",
    "else:\n",
    "    print(\"  No ID match found\")\n",
    "    print(f\"  Tried {len(candidate_ids)} aliases: {sorted(candidate_ids)}\")\n",
    "\n",
    "# ── Coordinate crossmatch ─────────────────────────────────────────────────────\n",
    "emc_ra  = float(toi700_rows[\"main_id_ra\"][0])\n",
    "emc_dec = float(toi700_rows[\"main_id_dec\"][0])\n",
    "emc_coord = SkyCoord(ra=emc_ra*u.deg, dec=emc_dec*u.deg)\n",
    "\n",
    "hpic_coords = SkyCoord(\n",
    "    ra=input_table[\"ra\"].astype(float)*u.deg,\n",
    "    dec=input_table[\"dec\"].astype(float)*u.deg,\n",
    ")\n",
    "seps = emc_coord.separation(hpic_coords)\n",
    "closest_idx = seps.argmin()\n",
    "closest_sep = seps[closest_idx]\n",
    "\n",
    "print(f\"\\n── Coordinate crossmatch ────────────────────────\")\n",
    "print(f\"  TOI-700 position: RA={emc_ra:.5f}°  Dec={emc_dec:.5f}°\")\n",
    "print(f\"  Closest HPIC star: '{input_table['star_name'][closest_idx]}'\")\n",
    "print(f\"  Separation: {closest_sep.to(u.arcsec):.2f}\")\n",
    "\n",
    "SEARCH_RADIUS = 30 * u.arcsec\n",
    "coord_matches = np.where(seps < SEARCH_RADIUS)[0]\n",
    "if len(coord_matches):\n",
    "    for idx in coord_matches:\n",
    "        print(f\"  MATCH within {SEARCH_RADIUS}: '{input_table['star_name'][idx]}'  \"\n",
    "              f\"sep={seps[idx].to(u.arcsec):.2f}\")\n",
    "else:\n",
    "    print(f\"  No match within {SEARCH_RADIUS} (closest is {closest_sep.to(u.arcsec):.1f})\")"
   ]
