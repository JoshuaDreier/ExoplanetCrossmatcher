   "source": [
    "confirmed_emc = np.array([str(s) == 'CONFIRMED' for s in e_cm_emc['status']])\n",
    "\n",
    "fig, ax = plt.subplots()\n",
    "\n",
    "for cat in CATEGORY_ORDER:\n",
    "    cat_mask = defined_mask & (np.array(e_cm_emc['spectral_category']) == cat)\n",
    "    conf   = cat_mask &  confirmed_emc\n",
    "    unconf = cat_mask & ~confirmed_emc\n",
    "    color  = CATEGORY_COLORS[cat]\n",
    "    if conf.sum():\n",
    "        ax.plot(m_emc[conf],  r_emc[conf],  '.', color=color, markersize=5,\n",
    "                label=f'{cat} — confirmed ({conf.sum()})')\n",
    "    if unconf.sum():\n",
    "        ax.plot(m_emc[unconf], r_emc[unconf], 'x', color=color, markersize=5, alpha=0.5,\n",
    "                label=f'{cat} — uncertain ({unconf.sum()})')\n",
    "\n",
    "ax.plot(m_curve, r_curve, '--', color='gray', linewidth=1, label='Hatzes & Rauer (2015)')\n",
    "ax.set_xscale('log')\n",
    "ax.set_yscale('log')\n",
    "ax.set_xlabel(r'$m~[M_\\oplus]$')\n",
    "ax.set_ylabel(r'$r~[R_\\oplus]$')\n",
    "ax.legend(fontsize=7)\n",
    "plt.show()"
   ]
  },
