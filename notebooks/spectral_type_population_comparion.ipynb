    "import pyvo\n",
    "\n",
    "# ── Unique confirmed rocky+temperate host stars with valid coordinates ─────────\n",
    "sample     = e_emc[mask_rt_conf]\n",
    "_, uidx    = np.unique([str(h) for h in sample['host']], return_index=True)\n",
    "uniq_hosts = sample[np.sort(uidx)]\n",
    "\n",
    "ra_arr  = np.array([float(r['main_id_ra'])  for r in uniq_hosts], dtype=float)\n",
    "dec_arr = np.array([float(r['main_id_dec']) for r in uniq_hosts], dtype=float)\n",
    "valid   = np.isfinite(ra_arr) & np.isfinite(dec_arr)\n",
    "\n",
    "upload_tbl = Table({\n",
    "    'host_name': [str(r['host']) for r in uniq_hosts[valid]],\n",
    "    'ra':        ra_arr[valid],\n",
    "    'dec':       dec_arr[valid],\n",
    "})\n",
    "print(f'Querying SIMBAD nearest neighbours for {len(upload_tbl)} host stars ...')\n",
    "\n",
    "# ── SIMBAD TAP batch cone search (30 arcsec radius) ───────────────────────────\n",
    "SEARCH_RADIUS_DEG = 1000.0 / 3600.0\n",
    "tap = pyvo.dal.TAPService('https://simbad.cds.unistra.fr/simbad/sim-tap')\n",
    "\n",
    "adql = f\"\"\"\n",
    "SELECT t.host_name,\n",
    "       b.main_id   AS neighbour_id,\n",
    "       b.otype     AS neighbour_type,\n",
    "       b.ra        AS neighbour_ra,\n",
    "       b.dec       AS neighbour_dec,\n",
    "       DISTANCE(POINT('ICRS', b.ra, b.dec),\n",
    "                POINT('ICRS', t.ra, t.dec)) * 3600.0 AS sep_arcsec\n",
    "FROM   TAP_UPLOAD.hosts AS t\n",
    "JOIN   basic            AS b\n",
    "  ON   CONTAINS(POINT('ICRS', b.ra, b.dec),\n",
    "                CIRCLE('ICRS', t.ra, t.dec, {SEARCH_RADIUS_DEG})) = 1\n",
    "\"\"\"\n",
    "\n",
    "nn_raw = tap.run_sync(adql, uploads={'hosts': upload_tbl}).to_table()\n",
    "\n",
    "# ── Sort in Python; drop self (sep ≈ 0); keep nearest neighbour per host ──────\n",
    "sep = np.array(nn_raw['sep_arcsec'], dtype=float)\n",
    "order = np.argsort(sep)\n",
    "nn_raw = nn_raw[order]\n",
    "sep    = sep[order]\n",
    "\n",
    "nn_filtered = nn_raw[sep > 0.5]\n",
    "\n",
    "seen, keep = set(), []\n",
    "for i, row in enumerate(nn_filtered):\n",
    "    h = str(row['host_name'])\n",
    "    if h not in seen:\n",
    "        seen.add(h)\n",
    "        keep.append(i)\n",
    "\n",
    "nn_nearest = nn_filtered[keep]\n",
    "nn_nearest.sort('sep_arcsec')\n",
    "\n",
    "print(f'Nearest neighbours found for {len(nn_nearest)}/{len(upload_tbl)} hosts\\n')\n",
    "nn_nearest[['host_name', 'neighbour_id', 'neighbour_type', 'sep_arcsec']]"
   ]
  }
