   "source": [
    "import plotly.graph_objects as go\n",
    "import numpy as np\n",
    "\n",
    "# Your x, y data (must be > 0 for log axes)\n",
    "x = np.random.exponential(scale=2, size=1000) + 0.1\n",
    "y = np.random.exponential(scale=3, size=1000) + 0.1\n",
    "\n",
    "# Bin in log-space manually\n",
    "n_bins = 30\n",
    "log_x_edges = np.linspace(np.log10(x.min()), np.log10(x.max()), n_bins + 1)\n",
    "log_y_edges = np.linspace(np.log10(y.min()), np.log10(y.max()), n_bins + 1)\n",
    "\n",
    "counts, _, _ = np.histogram2d(np.log10(x), np.log10(y),\n",
    "                               bins=[log_x_edges, log_y_edges])\n",
    "\n",
    "# Convert bin edges back to original scale for axis labels\n",
    "x_centers = 10 ** ((log_x_edges[:-1] + log_x_edges[1:]) / 2)\n",
    "y_centers = 10 ** ((log_y_edges[:-1] + log_y_edges[1:]) / 2)\n",
    "\n",
    "fig = go.Figure(data=go.Heatmap(\n",
    "    x=x_centers,\n",
    "    y=y_centers,\n",
    "    z=counts.T,\n",
    "    colorscale='Viridis',\n",
    "    colorbar=dict(title='Count'),\n",
    "))\n",
    "\n",
    "fig.update_xaxes(type='log', title='X (log scale)')\n",
    "fig.update_yaxes(type='log', title='Y (log scale)')\n",
    "fig.update_layout(title='2D Histogram with Log Axes', height=600, width=800)\n",
    "\n",
    "fig.show()"
   ]
  },
