    "catalog = e_cm_emc.copy()\n",
    "\n",
    "_, _keep = np.unique([str(n) for n in catalog['exo-mercat_name']], return_index=True)\n",
    "catalog = catalog[np.sort(_keep)]\n",
    "\n",
    "cats3 = ['Sun-like', 'Low-luminosity', 'Very-low-luminosity']\n",
    "\n",
    "cats_arr_cm = np.array(catalog['spectral_category'])\n",
    "\n",
    "rocky_mask_cm = rocky_mask(catalog['r_earth'], catalog['r_earth_min'], catalog['r_earth_max'], catalog['r_lower_bound'], catalog['r_upper_bound'],\n",
    "                            lower=0.5, upper=1.5, use_interval=USE_INTERVAL_ROCKY)\n",
    "temp_mask_cm   = temperate_mask(catalog['pl_insol'],\n",
    "                                 catalog['pl_insol_max'], catalog['pl_insol_min'],\n",
    "                                 lower=HZ_OUTER, upper=HZ_INNER,\n",
    "                                 use_interval=USE_INTERVAL_HZ)\n",
    "rocky_temp_cm  = rocky_mask_cm & temp_mask_cm\n",
    "rocky_other_cm = rocky_mask_cm & ~rocky_temp_cm\n",
    "\n",
    "# Attach classifications as table columns for easy filtering\n",
    "# Rocky confirmed = direct transit radius (r_earth not masked) + status CONFIRMED\n",
    "# Temperate confirmed = measured insolation (insol src) + status CONFIRMED\n",
    "_r_valid_cm      = ~np.ma.getmaskarray(np.ma.asarray(catalog['r_earth'], dtype=float))\n",
    "_status_conf_cm  = np.array(catalog['status']) == 'CONFIRMED'\n",
    "_insol_conf_cm   = np.array([s.startswith('insol') for s in catalog['pl_insol_src']])\n",
    "catalog['is_rocky']     = np.where(rocky_mask_cm,np.where(_r_valid_cm & _status_conf_cm, 'Confirmed', 'Uncertain'), '')\n",
    "catalog['is_temperate'] = np.where(temp_mask_cm,np.where(_insol_conf_cm & _status_conf_cm, 'Confirmed', 'Uncertain'), '')\n",
    "counts_other = np.array([int(((cats_arr_cm == c) & rocky_other_cm).sum()) for c in cats3])\n",
    "counts_temp  = np.array([int(((cats_arr_cm == c) & rocky_temp_cm ).sum()) for c in cats3])\n",
    "counts_total = counts_other + counts_temp\n",
    "\n",
    "print(f'{\"Category\":<25} {\"Rocky\":>6} {\"Temperate\":>10} {\"Temperate %\":>12}')\n",
    "for c, n, t in zip(cats3, counts_total, counts_temp):\n",
    "    pct = 100 * t / n if n else 0\n",
    "    print(f'{c:<25} {n:6d} {t:10d} {pct:11.1f}%')\n",
    "\n",
    "ntemp_conf_h = np.array([((cats_arr_cm == c) & (catalog['is_rocky'] == 'Confirmed') & (catalog['is_temperate'] == '')).sum() for c in CATEGORY_ORDER])\n",
    "ntemp_unc_h  = np.array([((cats_arr_cm == c) & (catalog['is_rocky'] == 'Uncertain') & (catalog['is_temperate'] == '')).sum() for c in CATEGORY_ORDER])\n",
    "temp_conf_h  = np.array([((cats_arr_cm == c) & (catalog['is_rocky'] != '') & (catalog['is_temperate'] == 'Confirmed')).sum() for c in CATEGORY_ORDER])\n",
    "temp_unc_h   = np.array([((cats_arr_cm == c) & (catalog['is_rocky'] != '') & (catalog['is_temperate'] == 'Uncertain')).sum() for c in CATEGORY_ORDER])\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(6, 4.5))\n",
    "plot_rocky_bars(ax, ntemp_conf_h, ntemp_unc_h, temp_conf_h, temp_unc_h,\n",
    "                r'Rocky exoplanets (0.5–1.5 $R_\\oplus$) around HPIC stars')\n",
    "plt.tight_layout()\n",
    "plt.ylim(0, 120)\n",
    "plt.xlim(-0.5, 3.5)\n",
    "plt.show()"
   ]
  },
