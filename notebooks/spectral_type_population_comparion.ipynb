   "source": [
    "HOVER_TEMPLATE = ('<b>%{text}</b><br>'\n",
    "                  'm = %{x:.3f}%{customdata[0]} M<sub>&#8853;</sub><br>'\n",
    "                  'r = %{y:.3f}%{customdata[1]} R<sub>&#8853;</sub>'\n",
    "                  '<extra></extra>')\n",
    "\n",
    "fig = go.Figure()\n",
    "errorbar_trace_indices = list(range(len(CATEGORY_ORDER)))\n",
    "\n",
    "for cat in CATEGORY_ORDER:\n",
    "    mask = defined_mask & (np.array(e_cm_emc['spectral_category']) == cat)\n",
    "    customdata = [[format_uncertainty(mlo, mhi), format_uncertainty(rlo, rhi)]\n",
    "                  for mlo, mhi, rlo, rhi in zip(\n",
    "                      m_err_low[mask], m_err_high[mask],\n",
    "                      r_err_low[mask], r_err_high[mask])]\n",
    "    fig.add_trace(go.Scatter(\n",
    "        x=m_emc[mask], y=r_emc[mask],\n",
    "        mode='markers',\n",
    "        marker=dict(size=6, color=CATEGORY_COLORS[cat]),\n",
    "        name=f'{cat} ({mask.sum()})',\n",
    "        text=emc_names[mask],\n",
    "        customdata=customdata,\n",
    "        hovertemplate=HOVER_TEMPLATE,\n",
    "        error_x=dict(type='data', array=m_err_high[mask], arrayminus=m_err_low[mask], visible=True),\n",
    "        error_y=dict(type='data', array=r_err_high[mask], arrayminus=r_err_low[mask], visible=True),\n",
    "    ))\n",
    "\n",
    "fig.add_trace(go.Scatter(\n",
    "    x=m_curve, y=r_curve,\n",
    "    mode='lines', line=dict(dash='dash', color='gray'),\n",
    "    name='Hatzes & Rauer (2015)', hoverinfo='skip',\n",
    "))\n",
    "\n",
    "fig.update_layout(\n",
    "    xaxis_title=r'$m~[M_\\oplus]$',\n",
    "    yaxis_title=r'$r~[R_\\oplus]$',\n",
    "    xaxis_type='log',\n",
    "    yaxis_type='log',\n",
    "    updatemenus=[dict(\n",
    "        type='buttons', direction='right',\n",
    "        x=1.0, xanchor='right', y=1.12, yanchor='top', showactive=True,\n",
    "        buttons=[\n",
    "            dict(label='Errorbars on',  method='restyle',\n",
    "                 args=[{'error_x.visible': True,  'error_y.visible': True},  errorbar_trace_indices]),\n",
    "            dict(label='Errorbars off', method='restyle',\n",
    "                 args=[{'error_x.visible': False, 'error_y.visible': False}, errorbar_trace_indices]),\n",
    "        ],\n",
    "    )],\n",
    ")\n",
    "\n",
    "display(HTML(fig.to_html(include_plotlyjs='cdn', full_html=False)))"
   ]
  },
