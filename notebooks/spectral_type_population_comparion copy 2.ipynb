    "import plotly.graph_objects as go\n",
    "import plotly\n",
    "\n",
    "plotly.offline.init_notebook_mode()\n",
    "\n",
    "rjup_to_rearth = u.R_jup.to(u.R_earth)\n",
    "mjup_to_mearth = u.M_jup.to(u.M_earth)\n",
    "\n",
    "def sanitize_errorbar(arr):\n",
    "    a = np.array(arr, dtype=float)\n",
    "    a[~(a > 0)] = np.nan\n",
    "    return a\n",
    "\n",
    "def format_uncertainty(err_low, err_high):\n",
    "    has_low, has_high = not np.isnan(err_low), not np.isnan(err_high)\n",
    "    if has_low and has_high:  return f'<sup>+{err_high:.3f}</sup><sub>-{err_low:.3f}</sub>'\n",
    "    if has_high:              return f'<sup>+{err_high:.3f}</sup>'\n",
    "    if has_low:               return f'<sub>-{err_low:.3f}</sub>'\n",
    "    return '?'\n",
    "\n",
    "r_emc = np.array(out_emc['r'],        dtype=float) * rjup_to_rearth\n",
    "m_emc = np.array(out_emc['bestmass'], dtype=float) * mjup_to_mearth\n",
    "\n",
    "r_err_low  = sanitize_errorbar(np.array(out_emc['r_min'],        dtype=float) * rjup_to_rearth)\n",
    "r_err_high = sanitize_errorbar(np.array(out_emc['r_max'],        dtype=float) * rjup_to_rearth)\n",
    "m_err_low  = sanitize_errorbar(np.array(out_emc['bestmass_min'], dtype=float) * mjup_to_mearth)\n",
    "m_err_high = sanitize_errorbar(np.array(out_emc['bestmass_max'], dtype=float) * mjup_to_mearth)\n",
    "\n",
    "emc_names     = np.array([str(n) for n in out_emc['exo-mercat_name']])\n",
    "emc_uncertain = np.array([str(s) in ('CANDIDATE', 'CONTROVERSIAL') for s in out_emc['status']])\n",
    "defined_mask  = (r_emc > 0) & (m_emc > 0)\n",
    "\n",
    "_MR_M1, _MR_M2, _MR_M3 = 2.0, 0.41 * 317.83, 0.080 * 333_000\n",
    "_MR_EXP = (0.28, 0.59, -0.04, 0.88)\n",
    "\n",
    "def mass_radius_relation(m_earth):\n",
    "    m  = np.asarray(m_earth, dtype=float)\n",
    "    a, b, c, d = _MR_EXP\n",
    "    A0 = 1.0\n",
    "    A1 = A0 * _MR_M1 ** (a - b)\n",
    "    A2 = A1 * _MR_M2 ** (b - c)\n",
    "    A3 = A2 * _MR_M3 ** (c - d)\n",
    "    r  = np.empty_like(m)\n",
    "    r[m <= _MR_M1]                       = A0 * m[m <= _MR_M1] ** a\n",
    "    s2 = (m > _MR_M1) & (m <= _MR_M2);  r[s2] = A1 * m[s2] ** b\n",
    "    s3 = (m > _MR_M2) & (m <= _MR_M3);  r[s3] = A2 * m[s3] ** c\n",
    "    r[m > _MR_M3]                        = A3 * m[m > _MR_M3] ** d\n",
    "    return r\n",
    "\n",
    "m_curve = np.logspace(np.log10(m_emc[defined_mask].min()), np.log10(m_emc[defined_mask].max()), 500)\n",
    "r_curve = mass_radius_relation(m_curve)\n",
    "\n",
    "CATEGORY_COLORS = {\n",
    "    'Sun-like':            '#F5A623',\n",
    "    'Low-luminosity':      '#E05C00',\n",
    "    'Very-low-luminosity': '#C0392B',\n",
    "    'Other':               '#95A5A6',\n",
    "}"
   ]
  },
