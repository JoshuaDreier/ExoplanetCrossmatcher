    "from crossmatching.enrichment import mass_radius_chen_kipping\n",
    "\n",
    "# \u2500\u2500 Inverse Chen & Kipping: radius (R_earth) \u2192 mass (M_earth) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "R_BOUNDARY = mass_radius_chen_kipping(2.04)  # \u2248 1.23 R_earth, Terran/Neptunian boundary\n",
    "\n",
    "def ck_inv(r_earth: float) -> float:\n",
    "    if r_earth < R_BOUNDARY:\n",
    "        return (r_earth / 1.008) ** (1 / 0.279)   # Terran regime\n",
    "    else:\n",
    "        return (r_earth / 0.808) ** (1 / 0.589)   # Neptunian regime\n",
    "\n",
    "ROCKY_LO, ROCKY_HI = 0.5, 1.5   # R_earth \u2014 matches rocky_mask defaults\n",
    "SIN_MIN = 0.5                    # msini_sin_min default in ParamFiller\n",
    "\n",
    "m_lo = ck_inv(ROCKY_LO)   # mass that gives r_lower_bound = ROCKY_LO\n",
    "m_hi = ck_inv(ROCKY_HI)   # mass that gives r_lower_bound = ROCKY_HI\n",
    "\n",
    "# r_lower_bound = CK(msini)             \u2192 passes iff msini \u2264 CK_inv(1.5)\n",
    "# r_upper_bound = CK(msini / sin_min)   \u2192 passes iff msini \u2265 sin_min \u00d7 CK_inv(0.5)\n",
    "msini_min = SIN_MIN * m_lo\n",
    "msini_max = m_hi\n",
    "\n",
    "print(f\"C&K regime boundary:  R = {R_BOUNDARY:.4f} R_earth  (= 2.04 M_earth)\")\n",
    "print()\n",
    "print(f\"Rocky window [{ROCKY_LO}, {ROCKY_HI}] R_earth  \u2194  true mass:\")\n",
    "print(f\"  R = {ROCKY_LO} R_earth  \u2192  {m_lo:.4f} M_earth  ({m_lo/317.83:.2e} M_Jup)\")\n",
    "print(f\"  R = {ROCKY_HI} R_earth  \u2192  {m_hi:.4f} M_earth  ({m_hi/317.83:.2e} M_Jup)\")\n",
    "print()\n",
    "print(f\"msini range that overlaps [{ROCKY_LO}, {ROCKY_HI}] R_earth  (sin_min = {SIN_MIN}):\")\n",
    "print(f\"  min  msini = sin_min \u00d7 CK_inv({ROCKY_LO}) = {SIN_MIN} \u00d7 {m_lo:.4f} = {msini_min:.4f} M_earth  ({msini_min/317.83:.2e} M_Jup)\")\n",
    "print(f\"  max  msini = CK_inv({ROCKY_HI})            =            {m_hi:.4f} = {msini_max:.4f} M_earth  ({msini_max/317.83:.2e} M_Jup)\")"
   ]
  },
