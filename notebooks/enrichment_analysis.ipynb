   "source": [
    "# \u2500\u2500 Flux / orbit parameter source breakdown \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "print('=== flux_rel_src ===')\n",
    "c_flux = Counter(str(v) for v in e_emc['flux_rel_src'])\n",
    "total  = len(e_emc)\n",
    "for src, count in c_flux.most_common():\n",
    "    tag = src if src else '(missing / uncomputable)'\n",
    "    print(f\"  {tag:<55}  {count:>6,}  {100*count/total:>4.1f}%\")\n",
    "\n",
    "print()\n",
    "print('=== a_src ===')\n",
    "for src, count in Counter(str(v) for v in e_emc['a_src']).most_common():\n",
    "    tag = src if src else '(missing)'\n",
    "    if not tag.startswith('kepler'):\n",
    "        print(f\"  {tag:<55}  {count:>6,}  {100*count/total:>4.1f}%\")\n",
    "    else:\n",
    "        print(f\"  kepler fallback (various mass sources)  {count:>6,}  {100*count/total:>4.1f}%\")\n",
    "        break  # all remaining are kepler variants\n",
    "\n",
    "print()\n",
    "print('=== st_lum_src ===')\n",
    "for src, count in Counter(str(v) for v in e_emc['st_lum_src']).most_common():\n",
    "    tag = src if src else '(missing)'\n",
    "    print(f\"  {tag:<55}  {count:>6,}  {100*count/total:>4.1f}%\")\n",
    "# \u2500\u2500 Uncertainty coverage \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "n_ferr = int((~np.ma.getmaskarray(e_emc['flux_rel_err1'])).sum())\n",
    "print(f'flux_rel_err: {n_ferr:,} / {total:,} ({100*n_ferr/total:.1f}% have uncertainty estimates)')"
   ]
